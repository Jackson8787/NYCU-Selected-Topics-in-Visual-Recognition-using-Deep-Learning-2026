{
  "data_dir": "nycu-hw2-data",
  "output_dir": "outputs/r50_480_aug",
  "model_name": "facebook/detr-resnet-50",
  "num_labels": 10,
  "num_queries": 100,
  "shortest_edge": 480,
  "longest_edge": 800,
  "batch_size": 8,
  "gradient_accumulation_steps": 1,
  "num_workers": 4,
  "persistent_workers": true,
  "prefetch_factor": 4,
  "epochs": 10,
  "learning_rate": 0.0001,
  "backbone_learning_rate": 0.00001,
  "weight_decay": 0.0001,
  "max_grad_norm": 0.1,
  "scheduler": "cosine",
  "warmup_ratio": 0.05,
  "min_lr_factor": 0.05,
  "seed": 42,
  "eval_every": 1,
  "amp": false,
  "augmentation": {
    "color_jitter": true
  }
}
