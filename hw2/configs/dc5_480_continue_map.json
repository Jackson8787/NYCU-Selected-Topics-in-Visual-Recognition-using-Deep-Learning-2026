{
  "data_dir": "nycu-hw2-data",
  "output_dir": "outputs/dc5_480_continue_map",
  "model_name": "facebook/detr-resnet-50-dc5",
  "init_checkpoint": "outputs/dc5_480_noaug_map/best",
  "num_labels": 10,
  "num_queries": 100,
  "shortest_edge": 480,
  "longest_edge": 800,
  "batch_size": 2,
  "gradient_accumulation_steps": 4,
  "num_workers": 4,
  "persistent_workers": true,
  "prefetch_factor": 4,
  "epochs": 6,
  "learning_rate": 0.00002,
  "backbone_learning_rate": 0.000002,
  "weight_decay": 0.0001,
  "max_grad_norm": 0.1,
  "scheduler": "cosine",
  "warmup_ratio": 0.0,
  "min_lr_factor": 0.1,
  "seed": 43,
  "eval_every": 1,
  "best_metric": "map",
  "map_batch_size": 2,
  "map_score_threshold": 0.001,
  "map_max_detections_per_image": 50,
  "amp": false,
  "augmentation": {
    "color_jitter": false
  }
}
