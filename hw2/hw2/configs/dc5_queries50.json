{
  "data_dir": "nycu-hw2-data",
  "output_dir": "outputs/dc5_queries50",
  "model_name": "facebook/detr-resnet-50-dc5",
  "num_labels": 10,
  "num_queries": 50,
  "shortest_edge": 640,
  "longest_edge": 1024,
  "batch_size": 1,
  "gradient_accumulation_steps": 4,
  "num_workers": 4,
  "persistent_workers": true,
  "prefetch_factor": 4,
  "epochs": 8,
  "learning_rate": 0.0001,
  "backbone_learning_rate": 0.00001,
  "weight_decay": 0.0001,
  "max_grad_norm": 0.1,
  "scheduler": "cosine",
  "warmup_ratio": 0.05,
  "min_lr_factor": 0.05,
  "seed": 42,
  "eval_every": 1,
  "amp": false,
  "augmentation": {
    "color_jitter": true
  }
}
